{
  "name": "logixia",
  "version": "1.0.3",
  "description": "TypeScript logger with custom log levels, multi-transport (console, file, DB, analytics), NestJS module, built-in search, request tracing, and zero-dep OpenTelemetry support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "cli:build": "tsc -p tsconfig.json --outDir dist/cli && cp -R src/cli/templates dist/cli 2>/dev/null || true",
    "cli:dev": "ts-node src/cli/index.ts",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "dev:basic-usage": "ts-node examples/basic-usage.ts",
    "dev:express": "ts-node examples/express-example.ts",
    "dev:nestjs": "ts-node examples/nestjs-example.ts",
    "dev:custom-levels": "ts-node examples/custom-levels.ts",
    "dev:performance": "ts-node examples/performance-monitoring.ts",
    "dev:fields": "ts-node examples/field-configuration.ts",
    "dev:search": "ts-node examples/search-quickstart.ts",
    "dev:intelligent-search": "ts-node examples/intelligent-search.ts",
    "lint:check": "eslint src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "commit": "cz"
  },
  "keywords": [
    "logger",
    "logging",
    "typescript",
    "typescript-logger",
    "nestjs",
    "nestjs-logger",
    "nestjs-logging",
    "nestjs-module",
    "winston-alternative",
    "pino-alternative",
    "structured-logging",
    "json-logging",
    "custom-log-levels",
    "log-levels",
    "request-tracing",
    "trace-id",
    "opentelemetry",
    "w3c-trace-context",
    "multi-transport",
    "console-transport",
    "file-transport",
    "log-rotation",
    "database-logging",
    "mongodb-logger",
    "postgresql-logger",
    "analytics-logging",
    "datadog",
    "mixpanel",
    "segment",
    "log-search",
    "log-analysis",
    "log-aggregation",
    "nodejs",
    "bun",
    "express",
    "microservices",
    "distributed-tracing",
    "observability",
    "developer-tools",
    "enterprise-logging"
  ],
  "author": {
    "name": "Sanjeev Sharma",
    "email": "webcoderspeed@gmail.com",
    "url": "https://github.com/webcoderspeed"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Logixia/logixia.git"
  },
  "bugs": {
    "url": "https://github.com/Logixia/logixia/issues"
  },
  "homepage": "https://github.com/Logixia/logixia#readme",
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "express": "^4.18.0",
    "reflect-metadata": "^0.1.13"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/types": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^10.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.5",
    "@types/uuid": "^9.0.0",
    "commitizen": "^4.3.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "express": "^4.18.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "lint-staged": "^16.3.3",
    "mongodb": "^6.20.0",
    "mysql2": "^3.14.5",
    "pg": "^8.16.3",
    "prettier": "^3.0.0",
    "semantic-release": "^24.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "uuid": "^9.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "logixia": "./dist/cli/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "inquirer": "^9.3.8",
    "ora": "^6.3.1"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,mjs,cjs}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  }
}
